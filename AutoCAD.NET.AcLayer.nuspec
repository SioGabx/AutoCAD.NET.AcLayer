<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
  <metadata>
    <id>AutoCAD.NET.AcLayer</id>
    <version>21.0.0</version>
    <title>AutoCAD .NET AcLayer</title>
    <authors>SioGabx</authors>
    <owners>Autodesk</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <projectUrl>https://github.com/SioGabx/AutoCAD.NET.AcLayer</projectUrl>
    <description>AcLayer library for AutoCAD. This package provides the AcLayer DLL which is generally not included in the official Autodesk NuGet packages.</description>
	<releaseNotes>Initial release of the missing AcLayer DLL.</releaseNotes>
    <copyright>Copyright Autodesk</copyright>
    <tags>autocad layer aclayer autodesk net plugin</tags>
    <readme>README.md</readme>
	<license type="file">LICENSE.md</license>
	<dependencies>
      <group targetFramework=".NETFramework4.7" />
    </dependencies>
  </metadata>
  
  <files>
  <file src="README.md" target="\" />
  <file src="LICENSE.md" target="\" />
    <file src="lib\net47\AcLayer.dll" target="lib\net47\" />
  </files>
</package>